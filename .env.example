# Leave all of these unset to run the frontend against mock data (no AWS
# account needed). Fill them in once the backend (see backend/template.yaml)
# is deployed to switch the UI over to live API Gateway + Cognito.

# Base URL of the deployed HTTP API, e.g.
# https://abc123.execute-api.ap-south-1.amazonaws.com/dev
VITE_API_BASE_URL=

# Cognito — customer pool (from `sam deploy` outputs)
VITE_CUSTOMER_USER_POOL_ID=
VITE_CUSTOMER_USER_POOL_CLIENT_ID=

# Cognito — vehicle owner pool (from `sam deploy` outputs)
VITE_OWNER_USER_POOL_ID=
VITE_OWNER_USER_POOL_CLIENT_ID=

# WebSocket API for realtime bid updates (the WebSocketUrl stack output),
# e.g. wss://abc123.execute-api.ap-south-1.amazonaws.com/dev
VITE_WS_URL=
